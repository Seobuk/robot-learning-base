outputs/
runs/
logs/
multirun/
wandb/
mlruns/
lightning_logs/
tensorboard/
checkpoints/
models/
videos/
.hydra/

# ─── ROS 2 / colcon generated (never commit, never hand-edit) ─
install/
log/
COLCON_IGNORE
.colcon/
ros2_ws/build/
ros2_ws/install/
ros2_ws/log/

# ─── Rosbags / recordings ───────────────────────────────
*.bag
*.db3
*.mcap
rosbag2_*/

