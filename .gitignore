*.pt
*.pth
*.onnx
*.safetensors
*.pb
*.h5
*.tflite
*.engine
*.plan
*.pkl
*.zip

# ─── Datasets: ignore blobs, keep DVC pointers + placeholder .gitignore ─
data/**
!data/**/*.dvc
!data/**/.gitignore

